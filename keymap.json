// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      // Ctrl jklk to move between panes
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      // Ctrl up/down/left/right resize pane
      "ctrl-up": "vim::ResizePaneUp",
      "ctrl-down": "vim::ResizePaneDown",
      "ctrl-left": "vim::ResizePaneLeft",
      "ctrl-right": "vim::ResizePaneRight",
    },
  },
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      // Put key bindings here (in addition to the context below) if you want them to
      // work when no editor exists.
      "space f v": [
        "task::Spawn",
        { "task_name": "Television File Finder", "reveal_target": "center" },
      ],
      "space f f": "file_finder::Toggle",
      "space f t": "text_finder::Toggle",
      "space f p": "pane::DeploySearch",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      // put key-bindings here if you want them to work in normal & visual mode
      "space f v": [
        "task::Spawn",
        { "task_name": "Television File Finder", "reveal_target": "center" },
      ],
      "space f f": "file_finder::Toggle",
      "space f t": "text_finder::Toggle",
      "space f p": "pane::DeploySearch",
      "g z": "vim::HelixJumpToWord",
      "g '": "git::Diff",
      "alt-]": "editor::ShowEditPrediction",
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // put key-bindings here if you want them to work only in normal mode
      "enter": ["workspace::SendKeystrokes", "o escape k"],
      "shift-enter": ["workspace::SendKeystrokes", "O escape j"],
    },
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      // put key-bindings here if you want them to work only in visual mode
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      // put key-bindings here if you want them to work only in insert mode
      "alt-]": "editor::ShowEditPrediction",
    },
  },
  {
    // Which key
    "context": "(VimControl && !menu)",
    "bindings": {
      "space": null, // Disable the default action vim::WrappingRight
      "ctrl-w": null,
    },
  },
  {
    // move up or down a visual line instead of a complete line in markdown and text files
    "context": "VimControl && !menu && (extension == md || extension == txt)",
    "bindings": {
      "j": ["workspace::SendKeystrokes", "g j"],
      "down": ["workspace::SendKeystrokes", "g j"],
      "k": ["workspace::SendKeystrokes", "g k"],
      "up": ["workspace::SendKeystrokes", "g k"],
    },
  },
]
